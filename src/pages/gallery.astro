---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title = "RichardMe123 | Gallery">
    <main class="gallery-body">
        <h2 class="ui-title-2" style="margin: 30px; font-size:2.4rem;">Some of my Illustrations</h2>
        <div class="grid">
            <div class="grid-item">
                <img src="/assets/illustrations/Pless_myLove.webp" alt="Pless Drawing">
            </div>
            <div class="grid-item">
                <img src="/assets/illustrations/Lukie.webp" alt="Luke Drawing">
            </div>
            <div class="grid-item">
                <img src="/assets/illustrations/Renaat.webp" alt="Renaat Drawing">
            </div>
            <div class="grid-item">
                <img src="/assets/illustrations/garden-bg.webp" alt="Illustation in Garden">
            </div>
            <div class="grid-item">
                <img src="/assets/illustrations/me-blue.webp" alt="Illustation of me">
            </div>
            <div class="grid-item">
                <img src="/assets/illustrations/me-jumper.webp" alt="Portrait Illustration">
            </div>
            <div class="grid-item">
                <img src="/assets/illustrations/lenny.webp" alt="Lenny Drawing">
            </div>
        </div>
    </main>
</BaseLayout>
