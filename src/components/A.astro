---
const { link } = Astro.props;
---

<a href={link} rel="noreferrer noopener" target="_blank"><slot /></a>

<style>
a{ 
    position: relative;
    color: inherit;
}
a:hover {
    text-decoration: none;
}

a:hover::after {
    height: 4px;
}

a::after {
    content: '';
    width: 100%;
    height: 0;
    background: rgb(137, 163, 137);
    position: absolute;
    left: 0;
    top: 100%;
    transition: height 0.3s ease;  
}
</style>